# UNA TANTUM VOCE - Backend Environment
# Copy to .env and configure. NEVER commit .env

# App
APP_NAME=UNA TANTUM VOCE
APP_ENV=development
DEBUG=True

# Database — SQLite for local dev, PostgreSQL for production
# Local: sqlite:///./utv.db
# Production: postgresql://user:pass@host:5432/utv_db
DATABASE_URL=sqlite:///./utv.db

# Security — generate with: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin setup — required header to call /api/auth/admin-setup
# generate with: openssl rand -hex 32
ADMIN_SETUP_SECRET=

# Admin credentials — SET UNIQUE VALUES, never use defaults in production
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:5173

# ─── Optional Services (graceful degradation if not set) ───────────────────

# AWS S3 / Cloudflare R2 (REQUIRED in production — local disk fallback in dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_ENDPOINT_URL=
S3_CUSTOM_DOMAIN=

# Stripe (optional — payment features disabled without)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (optional — emails silently skipped if not configured)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_ENABLED=False

# OpenAI (optional — AI assistant uses keyword fallback if not set)
OPENAI_API_KEY=

# YouTube Data API v3 (optional — video sync disabled without, embeds still work)
# Get key at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=
# Channel ID for @UNATANTUMVOCEOFFICIAL — leave empty to auto-detect via channel handle
YOUTUBE_CHANNEL_ID=
